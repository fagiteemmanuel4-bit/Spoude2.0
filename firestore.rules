rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles: Users can read and write only their own profile
    match /profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Materials: Users can read/write only their own materials
    match /materials/{materialId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || resource.data.is_public == true);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Study Sets: Users can read/write only their own study sets
    match /study_sets/{setId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Attempts: Users can read/write only their own attempts
    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Account Events: Users can read/write only their own account events
    match /account_events/{eventId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // AI Usage: Users can read/write only their own AI usage logs
    match /ai_usage/{usageId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    // Posts: Social posts can be read by any authenticated user, written only by the author
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
  }
}
